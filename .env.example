# AI Employee Environment Configuration
# Copy this file to .env and fill in your values

# ======================
# Vault Settings
# ======================
VAULT_PATH=~/AI_Employee_Vault
WATCH_PATH=~/AI_Drop
DRY_RUN=true

# ======================
# Gmail SMTP Settings
# ======================
# Used by the Email MCP server to send emails

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...

# To get an App Password for Gmail:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication (required)
# 3. Go to App Passwords (search for it in account settings)
# 4. Generate a new app password for "Mail"
# 5. Copy the 16-character password here (no spaces)

# ======================
# Optional Settings
# ======================

# Debug mode
# DEBUG=true

ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee_db
ODOO_LOGIN=...
ODOO_PASSWORD=...
# Note: uses login password for XML-RPC auth

# ======================
# Facebook / Instagram
# ======================
# Both use the same Page Access Token (from Meta Developer App)
# Facebook: https://developers.facebook.com → your app → Graph API Explorer
# Instagram: requires a Facebook Page linked to an Instagram Business Account
FB_PAGE_ACCESS_TOKEN=...
FB_PAGE_ID=...
IG_USER_ID=...

# ======================
# Twitter / X
# ======================
# Create app at https://developer.twitter.com → Keys and Tokens
# Requires OAuth 1.0a user context (Read + Write permissions)
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# Set to true to demo without real API tokens (auto-enabled when tokens missing)
SOCIAL_DRY_RUN=false